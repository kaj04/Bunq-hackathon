# ── Bunq Sandbox ─────────────────────────────────────────────────────────────
# Generate a fresh API key at https://sandbox.bunq.com → Settings → API Keys
# userId and accountId are fetched automatically at runtime — no need to set them.
BUNQ_API_KEY=sandbox_YOUR_KEY_HERE

# Set to "true" during local development to bypass all Bunq API calls.
# Uses mock payments from lib/bunq/mock-data.ts instead.
BUNQ_MOCK=false

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Renamed from ANTHROPIC_API_KEY to avoid conflict with the Claude Code CLI,
# which injects an empty ANTHROPIC_API_KEY that Next.js cannot override.
APP_CLAUDE_KEY=sk-ant-api03-YOUR_KEY_HERE
